# Home Assistant connection (AD-8).
# Copy this file to `.env.local` (gitignored) and fill in real values.
# NEVER commit `.env.local` or put a real token here. The token is injected at
# runtime by Vite and must never appear in the committed repo or in dist/.

# HA base URL, e.g. http://homeassistant.local:8123
VITE_HA_URL=

# HA long-lived access token.
# Create one in HA: profile → "Long-lived access tokens" → Create token.
# Optional if the app is served same-origin from HA (HA-session variant).
VITE_HA_TOKEN=

# Optional: entity_id shown live in the connection view (else auto-picked).
# VITE_HA_WITNESS_ENTITY=sensor.salon_temperature

# --- NutriClaude / Courses (v2, AD-12/AD-13) — see docs/nutriclaude.md ---
# PUBLIC config (safe, bounded by the household RLS): Supabase project URL + anon
# key. Fill these in `.env.local`; they may be inlined in the build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Kitchen-account login. DEV ONLY — used once to establish the session, which is
# then persisted by supabase-js. NEVER set the password for a production build:
# a VITE_ var is inlined into dist/. `vite.config.ts` throws if it is (AD-13).
# The prod one-time setup login is a follow-on story.
# VITE_NUTRICLAUDE_CUISINE_EMAIL=
# VITE_NUTRICLAUDE_CUISINE_PASSWORD=
